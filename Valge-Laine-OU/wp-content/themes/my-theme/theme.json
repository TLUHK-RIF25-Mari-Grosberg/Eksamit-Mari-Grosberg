{
  "$schema": "https://schemas.wp.org/wp/7.0/theme.json",
  "version": 3,

  "settings": {
    "appearanceTools": true,

    "layout": {
      "contentSize": "620px",
      "wideSize": "1000px"
    },

    "spacing": {
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    },

    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#19869C"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "color": "#13263C"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#fafafa"
        },
        {
          "slug": "surface-raised",
          "name": "Surface Raised",
          "color": "#f5f5f5"
        }
      ]
    },

    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Outfit, sans-serif",
          "slug": "outfit",
          "name": "Outfit",
          "fontFace": [
            {
              "fontFamily": "Outfit",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "url('/wp-content/uploads/fonts/Outfit-Regular.ttf') format('truetype')"
              ]
            }
          ]
        },
        {
          "fontFamily": "'EB Garamond', serif",
          "slug": "eb-garamond",
          "name": "EB Garamond",
          "fontFace": [
            {
              "fontFamily": "EB Garamond",
              "fontStyle": "italic",
              "fontWeight": "500",
              "src": [
                "url('/wp-content/uploads/fonts/EBGaramond-MediumItalic.ttf') format('truetype')"
              ]
            },
            {
              "fontFamily": "EB Garamond",
              "fontStyle": "italic",
              "fontWeight": "600",
              "src": [
                "url('/wp-content/uploads/fonts/EBGaramond-SemiBoldItalic.ttf') format('truetype')"
              ]
            }
          ]
        }
      ],

      "defaultFontSizes": false,
      "fontSizes": [
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "1rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "1.25rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "1.5rem"
        },
        {
          "slug": "xxl",
          "name": "XXL",
          "size": "2rem"
        },
        {
          "slug": "xxxl",
          "name": "XXXL",
          "size": "2.5rem"
        }
      ]
    },

    "useRootPaddingAwareAlignments": true
  },

  "styles": {
    "color": {
      "background": "var(--wp--preset--color--primary)",
      "text": "var(--wp--preset--color--heading)"
    },

    "typography": {
      "fontFamily": "var(--wp--preset--font-family--outfit)",
      "fontSize": "var(--wp--preset--font-size--md)"
    },

    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--eb-garamond)",
          "fontStyle": "italic",
          "fontWeight": "600",
          "fontSize": "var(--wp--preset--font-size--xl)"
        },
        "color": {
          "text": "var(--wp--preset--color--heading)"
        }
      },

      "link": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--eb-garamond)",
          "fontStyle": "italic",
          "fontWeight": "500"
        },
        "color": {
          "text": "var(--wp--preset--color--heading)"
        }
      }
    }
  },

  "templateParts": [
    {
      "area": "header",
      "name": "header"
    },
    {
      "area": "footer",
      "name": "footer"
    }
  ]
}